{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EaaSGrid Deployment Package",
  "type": "object",
  "required": [
    "website_id",
    "environment",
    "version",
    "package_status",
    "deployment_status"
  ],
  "properties": {
    "website_id": {
      "type": "string",
      "minLength": 1
    },
    "environment": {
      "type": "string",
      "enum": [
        "local",
        "staging",
        "production"
      ]
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "package_status": {
      "type": "string",
      "enum": [
        "ready"
      ]
    },
    "deployment_status": {
      "type": "string",
      "enum": [
        "pending",
        "deployed",
        "failed",
        "rolled_back"
      ]
    }
  },
  "additionalProperties": false
}
