{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EaaSGrid Website Factory Page Structure",
  "type": "object",
  "required": [
    "structure",
    "pages"
  ],
  "properties": {
    "structure": {
      "enum": [
        "one-page",
        "multi-page",
        "hybrid"
      ]
    },
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "sections": {
            "type": "array"
          }
        }
      }
    }
  }
}
