{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Deployment Orchestration Request",
  "type": "object",
  "required": [
    "website_id",
    "environment",
    "version"
  ],
  "properties": {
    "website_id": {
      "type": "string",
      "minLength": 1
    },
    "environment": {
      "type": "string",
      "enum": [
        "development",
        "staging",
        "production"
      ]
    },
    "version": {
      "type": "string",
      "minLength": 1
    }
  },
  "additionalProperties": false
}
