  "required": [
    "theme",
    "source",
    "status",
    "tokens"
  ],
  "properties": {
    "theme": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "renderable"
      ]
    },
    "tokens": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
