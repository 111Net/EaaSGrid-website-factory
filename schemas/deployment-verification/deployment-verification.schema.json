{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://eaasgrid.local/schemas/deployment-verification/deployment-verification.schema.json",
  "title": "EaaSGrid Deployment Verification",
  "type": "object",
  "required": [
    "deployment_id",
    "verification_status",
    "health_status"
  ],
  "properties": {
    "deployment_id": {
      "type": "string"
    },
    "verification_status": {
      "type": "string",
      "enum": [
        "verified",
        "rejected"
      ]
    },
    "health_status": {
      "type": "string",
      "enum": [
        "healthy",
        "unhealthy"
      ]
    }
  },
  "additionalProperties": false
}
