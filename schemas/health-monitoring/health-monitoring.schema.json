{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EaaSGrid Runtime Health Monitoring",
  "type": "object",
  "required": ["health_checks"],
  "properties": {
    "health_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "target_id",
          "target_type",
          "status",
          "checked_at"
        ],
        "properties": {
          "target_id": {
            "type": "string",
            "minLength": 1
          },
          "target_type": {
            "type": "string",
            "enum": [
              "runtime",
              "environment",
              "preview"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "healthy",
              "degraded",
              "unhealthy",
              "unknown"
            ]
          },
          "checked_at": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
